# Path to GCP service account JSON key
CREDENTIALS=../keys/gcp_credentials.json

# GCP project settings
PROJECT_ID=[your-gcp-project-id]
REGION=[your-region]            
LOCATION=[your-location]      

# GCS bucket that will receive the Parquet files
BUCKET_NAME=[your-gcs-bucket-name]

# BigQuery dataset 
DATASET_ID=[your-dataset-id]

# MotherDuck personal access token (Settings → Access Tokens at motherduck.com)
MOTHERDUCK_TOKEN=[your-motherduck-pat-token]

# MotherDuck database name (created in the MotherDuck UI) where the crash data will be stored
MOTHERDUCK_DATABASE=[your-motherduck-database]
